{
  "name": "azan-dashboard-v2",
  "version": "1.0.0",
  "description": "Prayer time management dashboard with automated Alexa announcements",
  "main": "src/server.js",
  "scripts": {
    "test": "jest --runInBand",
    "start": "node src/server.js",
    "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "server:dev": "nodemon src/server.js",
    "client:dev": "cd client && npm run dev",
    "client:install": "cd client && npm install"
  },
  "keywords": [
    "azan",
    "prayer",
    "dashboard",
    "alexa",
    "muslim"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.13.2",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "luxon": "^3.7.2",
    "multer": "^2.0.2",
    "node-schedule": "^2.1.1",
    "number-to-words": "^1.2.4",
    "play-sound": "^1.1.6",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "jest": "^30.2.0",
    "nodemon": "^3.1.11",
    "supertest": "^7.2.2"
  }
}
