{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@adapters/*": ["src/adapters/*"],
      "@config/*": ["src/config/*"],
      "@services/*": ["src/services/*"],
      "@utils/*": ["src/utils/*"],
      "@controllers/*": ["src/controllers/*"],
      "@middleware/*": ["src/middleware/*"],
      "@routes/*": ["src/routes/*"]
    }
  },
  "exclude": ["node_modules", "dist", "client"]
}
