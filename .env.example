# Application Configuration
PORT=3000
BASE_URL=http://localhost:3000

# VoiceMonkey Configuration
VOICEMONKEY_access_token=your_access_token_here
VOICEMONKEY_secret_token=your_secret_token_here

# Will be set automatically during setup
# ADMIN_PASSWORD=your_secure_password_here
# JWT_SECRET=some_long_random_string

# Suppress dotenv warnings
DOTENV_CONFIG_QUIET=true

# Python Microservice Configuration
PYTHON_SERVICE_URL=http://localhost:8000
