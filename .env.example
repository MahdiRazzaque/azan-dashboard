# Application Configuration
PORT=3000
BASE_URL=http://localhost:3000

# Should be set automatically during setup/startup
# ADMIN_PASSWORD=your_secure_password_here
# JWT_SECRET=some_long_random_string (auto-generated on startup if missing)
# ENCRYPTION_SALT=some_random_salt_string (auto-generated on startup if missing)

# Should be set automatically from settings
# VOICEMONKEY_TOKEN=youre_voice_monkey_token
# VOICEMONKEY_DEVICE=your_voice_monkey_device_id

# Suppress dotenv warnings
DOTENV_CONFIG_QUIET=true

# Python Microservice Configuration
PYTHON_SERVICE_URL=http://localhost:8000